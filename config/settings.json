{
  "pipeline": {
    "run_interval_minutes": 120,
    "max_events_per_run": 100,
    "stale_lock_threshold_minutes": 15,
    "heartbeat_interval_seconds": 60,
    "heartbeat_max_consecutive_errors": 5
  },
  "ingestion": {
    "max_events_per_domain": 8,
    "per_domain_caps": {
      "osint613.com": 4
    },
    "max_article_age_days": 2,
    "fetch_full_text": false,
    "query_language": "en",
    "max_event_age_days": 30,
    "max_event_future_days": 1
  },
  "classification": {
    "deterministic_prescreen_enabled": true,
    "deterministic_skip_floor": 15,
    "llm_batch_size": 6
  },
  "dedup": {
    "url_hash_algorithm": "sha256",
    "maturation_window_hours": 2,
    "content_similarity_threshold": 0.5,
    "title_similarity_threshold": 0.65,
    "title_token_jaccard_threshold": 0.72,
    "content_shingle_threshold": 0.4
  },
  "scoring": {
    "proximity_bonus": 30,
    "czib_bonus": 20,
    "aviation_nexus_bonus": 15,
    "safety_severity_cap": 40,
    "safety_lift_cap_on_mass_casualty": true,
    "incident_gate_cap": 50,
    "max_severity": 100,
    "llm_confidence_weight": 0.4,
    "anchor_confidence_weight": 0.3,
    "diversity_weight": 0.3,
    "casualty_bonus": {
      "deaths_threshold": 3,
      "injuries_threshold": 10,
      "bonus_points": 20
    }
  },
  "storyline": {
    "jaccard_threshold": 0.4,
    "country_match_required": true,
    "time_window_days": 14,
    "anchor_assist_threshold": 0.2,
    "anchor_assist_max_hours": 72,
    "llm_adjudication_enabled": true,
    "adjudication_window_hours": 48,
    "adjudication_max_candidates": 6
  },
  "narrative": {
    "enabled": true,
    "min_severity": 65,
    "min_events": 2,
    "max_per_run": 10,
    "lookback_days": 14
  },
  "alert": {
    "suppression_ttl_hours": 4,
    "new_activity_window_hours": 24,
    "alert_max_age_days": 2,
    "storyline_quiet_hours": 12,
    "tiers": {
      "CRITICAL": {
        "severity_min": 80,
        "confidence_min": 0.8,
        "anchor_confidence": [
          "HIGH"
        ],
        "time_certainty_exclude": [
          "unknown"
        ]
      },
      "ALERT": {
        "severity_min": 65,
        "confidence_min": 0.65,
        "anchor_confidence": [
          "HIGH",
          "MEDIUM"
        ],
        "time_certainty_exclude": [
          "unknown"
        ]
      },
      "WATCH": {
        "severity_min": 45,
        "confidence_min": 0.5,
        "anchor_confidence": [
          "HIGH",
          "MEDIUM",
          "LOW"
        ],
        "time_certainty_include": [
          "same_day",
          "previous_day"
        ]
      }
    }
  },
  "cold_storage": {
    "archive_endpoint": "",
    "retry_attempts": 3,
    "batch_size": 500,
    "archive_null_occurred_after_days": 60
  },
  "radius_mapping": {
    "airport": 5.0,
    "hotel_chain": 2.0,
    "port": 10.0,
    "military_base": 15.0
  },
