{
  "app": {
    "title": "SIM",
    "subtitle": "Security Incident Monitor — Aviation OSINT Intelligence",
    "page_icon": "🛡️",
    "layout": "wide",
    "auto_refresh_seconds": 60
  },
  "theme": {
    "primary": "#6366F1",
    "secondary": "#8B5CF6",
    "accent": "#06B6D4",
    "background": "#0B1120",
    "surface": "#151E32",
    "surface_light": "#1E293B",
    "surface_hover": "#243447",
    "text_primary": "#F8FAFC",
    "text_secondary": "#94A3B8",
    "text_muted": "#64748B",
    "border": "#334155",
    "success": "#10B981",
    "warning": "#F59E0B",
    "error": "#EF4444",
    "info": "#3B82F6"
  },
  "tiers": {
    "CRITICAL": {
      "color": "#EF4444",
      "bg": "rgba(239,68,68,0.12)",
      "border": "rgba(239,68,68,0.40)",
      "icon": "🔴",
      "label": "CRITICAL"
    },
    "ALERT": {
      "color": "#F97316",
      "bg": "rgba(249,115,22,0.12)",
      "border": "rgba(249,115,22,0.40)",
      "icon": "🟠",
      "label": "ALERT"
    },
    "WATCH": {
      "color": "#EAB308",
      "bg": "rgba(234,179,8,0.12)",
      "border": "rgba(234,179,8,0.40)",
      "icon": "🟡",
      "label": "WATCH"
    }
  },
  "status": {
    "raw":        { "color": "#3B82F6", "bg": "rgba(59,130,246,0.12)", "label": "Raw" },
    "deduped":    { "color": "#8B5CF6", "bg": "rgba(139,92,246,0.12)", "label": "Deduped" },
    "locked":     { "color": "#F59E0B", "bg": "rgba(245,158,11,0.12)", "label": "Locked" },
    "classified": { "color": "#06B6D4", "bg": "rgba(6,182,212,0.12)", "label": "Classified" },
    "scored":     { "color": "#10B981", "bg": "rgba(16,185,129,0.12)", "label": "Scored" },
    "reconciled": { "color": "#22C55E", "bg": "rgba(34,197,94,0.12)", "label": "Reconciled" },
    "archived":   { "color": "#64748B", "bg": "rgba(100,116,139,0.12)", "label": "Archived" }
  },
  "map": {
    "initial_latitude": 25.0,
    "initial_longitude": 20.0,
    "initial_zoom": 2,
    "style": "mapbox://styles/mapbox/dark-v11"
  }
}
