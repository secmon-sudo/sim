[supabase]
url = "https://PROJE_ID.supabase.co"
key = "eyJhbGci...SERVICE_ROLE_KEY_HERE"

[database]
url = "postgresql://postgres:SIFRE@db.PROJE_ID.supabase.co:5432/postgres"

[llm]
groq_key_a = "gsk_..."
groq_key_b = "gsk_..."
openrouter_key_a = "sk-or-v1-..."
openrouter_key_b = "sk-or-v1-..."
